# Server
PORT=8080
NODE_ENV=development

# Google OAuth (used for agent login via Google Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT signing secret (generate a random string, at least 32 characters)
JWT_SECRET=a-random-secret-string-at-least-32-chars

# Google Sheets — main spreadsheet tracked by the app
SPREADSHEET_ID=your-google-sheets-spreadsheet-id

# Google Docs — template used to generate conditional offer letters
OFFER_TEMPLATE_DOC_ID=your-google-doc-template-id

# Google Drive — folder where generated offer letters are stored
OFFER_OUTPUT_FOLDER_ID=your-google-drive-folder-id

# Gmail — sender address for offer letter emails
GMAIL_USER=your-email@unisza.edu.my

# Google Service Account (used for Sheets, Drive, Docs, and Gmail APIs)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS origin (frontend dev server)
FRONTEND_URL=http://localhost:3000
